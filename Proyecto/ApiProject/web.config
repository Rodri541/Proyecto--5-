<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.webServer>
        <!-- Configura IISNode para manejar solicitudes a Node.js -->
        <handlers>
            <add name="iisnode" path="index.js" verb="*" modules="iisnode" />
        </handlers>

        <!-- Reescribe todas las solicitudes al archivo index.js -->
        <rewrite>
            <rules>
                <rule name="Node.js API" stopProcessing="true">
                    <match url=".*" />
                    <action type="Rewrite" url="index.js" />
                </rule>
            </rules>
        </rewrite>

        <!-- Configuración de errores para mostrar detalles en caso de problemas -->
        <httpErrors errorMode="Detailed" />

        <!-- Configuración específica para IISNode -->
        <iisnode 
            loggingEnabled="true" 
            devErrorsEnabled="true" 
            node_env="development" />

        <!-- Opcional: configura la salida de logs en un archivo específico -->
        <system.diagnostics>
            <trace>
                <listeners>
                    <add name="iisnodeLog" type="System.Diagnostics.TextWriterTraceListener" initializeData="iisnode.log" />
                </listeners>
            </trace>
        </system.diagnostics>
<httpErrors errorMode="Detailed" />
    </system.webServer>
</configuration>